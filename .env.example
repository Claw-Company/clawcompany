# ClawCompany Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# REQUIRED: ClawAPI (default model supplier)
# ============================================
# Get your key at https://clawapi.org
CLAWAPI_KEY=sk-claw-your_key_here

# ============================================
# OPTIONAL: Additional model suppliers
# ============================================
# Add any of these to use models from other providers.
# ClawAPI works for everything out of the box — these are optional.

# Anthropic (direct)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (direct)
# OPENAI_API_KEY=sk-xxxxx

# Google AI
# GOOGLE_API_KEY=AIzaSy-xxxxx

# DeepSeek
# DEEPSEEK_API_KEY=sk-deep-xxxxx

# ============================================
# SERVER
# ============================================
PORT=3200
# DATABASE_URL=postgresql://... (leave unset for embedded PGlite)
