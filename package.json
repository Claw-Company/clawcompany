{
  "name": "clawcompany",
  "version": "0.1.0",
  "private": true,
  "description": "Build for WEB4.0, Claws Autonomous. Your AI company, one key to run them all.",
  "homepage": "https://clawcompany.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/Claw-Company/clawcompany.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "pnpm run --filter @clawcompany/server dev",
    "dev:all": "pnpm run --filter @clawcompany/server dev & pnpm run --filter @clawcompany/ui dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "db:generate": "pnpm --filter @clawcompany/db generate",
    "db:migrate": "pnpm --filter @clawcompany/db migrate",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
